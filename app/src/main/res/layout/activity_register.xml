<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Реєстрація"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Створіть акаунт покупця"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="32dp"/>

        <!-- Ім'я -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ІМ'Я ТА ПРІЗВИЩЕ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="Іваненко Олег"
            android:inputType="textPersonName"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Телефон -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="НОМЕР ТЕЛЕФОНУ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="+380 XX XXX XX XX"
            android:inputType="phone"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="example@gmail.com"
            android:inputType="textEmailAddress"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Пароль -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПАРОЛЬ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="Мінімум 4 символи"
            android:inputType="textPassword"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Підтвердження паролю -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПІДТВЕРДІТЬ ПАРОЛЬ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPasswordConfirm"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="Повторіть пароль"
            android:inputType="textPassword"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"/>

        <!-- Кнопка реєстрації -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_button_primary"
            android:text="ЗАРЕЄСТРУВАТИСЬ"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Посилання на вхід -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Вже є акаунт? "
                android:textColor="@color/text_secondary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Увійти"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>