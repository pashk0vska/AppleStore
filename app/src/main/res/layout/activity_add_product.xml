<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Назад -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Назад"
            android:textColor="@color/accent"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Новий товар"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Назва -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="НАЗВА ТОВАРУ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="iPhone 17 Pro 256GB"
            android:inputType="text"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Категорія -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="КАТЕГОРІЯ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:id="@+id/categoryChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"/>

        <!-- Опис -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ОПИС"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="Опис товару..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Ціна -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ЦІНА (₴)"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="49999"
            android:inputType="numberDecimal"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Стара ціна -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="СТАРА ЦІНА (₴) — необов'язково"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etOldPrice"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="55000"
            android:inputType="numberDecimal"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Кількість -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="КІЛЬКІСТЬ НА СКЛАДІ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etStock"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="10"
            android:inputType="number"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- URL фото -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URL ФОТО"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etImageUrl"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="https://..."
            android:inputType="textUri"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"/>

        <!-- Кнопка додати -->
        <Button
            android:id="@+id/btnAddProduct"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_button_primary"
            android:text="ДОДАТИ ТОВАР"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>