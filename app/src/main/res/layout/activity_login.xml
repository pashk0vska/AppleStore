<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:gravity="center_horizontal">

    <!-- Верхня частина з логотипом -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <!-- Логотип -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="180dp"
            android:layout_height="66dp"
            android:src="@drawable/ic_logo"
            android:scaleType="fitCenter"
            android:layout_marginBottom="8dp"/>

        <!-- Підзаголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Увійдіть для роботи з системою"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="48dp"/>

        <!-- Поле Логін -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ЛОГІН"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="Логін / Телефон / Email"
            android:inputType="text"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Поле Пароль -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ПАРОЛЬ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_disabled"
            android:hint="Пароль"
            android:inputType="textPassword"
            android:textSize="15sp"
            android:layout_marginBottom="8dp"/>

        <!-- Забули пароль -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Забули пароль?"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:gravity="end"
            android:layout_marginBottom="28dp"/>

        <!-- Кнопка Увійти -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_primary"
            android:text=" УВІЙТИ"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Реєстрація -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Немає акаунту? "
                android:textColor="@color/text_secondary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Зареєструватись"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Нижня частина -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Apple Store Manager v1.0"
        android:textColor="@color/text_disabled"
        android:textSize="11sp"
        android:layout_marginBottom="24dp"/>

</LinearLayout>